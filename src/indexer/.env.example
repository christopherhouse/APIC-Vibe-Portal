# ============================================================
# Indexer Environment Variables
# Copy to .env and fill in values for local development
# ============================================================

# Logging
LOG_LEVEL=INFO

# Azure Managed Identity
# Client ID of the User-Assigned Managed Identity (UAMI) assigned to the
# Container Apps Job.  Set to the value of the 'indexerIdentityClientId'
# output from the Bicep deployment.  Leave empty for local development.
AZURE_CLIENT_ID=<indexerIdentityClientId-from-bicep-output>

# Azure AI Search
AI_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AI_SEARCH_INDEX_NAME=apic-apis

# Azure OpenAI
OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
OPENAI_EMBEDDING_DIMENSIONS=1536

# Azure API Center
API_CENTER_SUBSCRIPTION_ID=<your-subscription-id>
API_CENTER_RESOURCE_GROUP=<your-resource-group>
API_CENTER_SERVICE_NAME=<your-api-center-name>

# Indexing behaviour
EMBEDDING_CHUNK_SIZE=8000

# Cron schedule for the Azure Container Apps Job trigger (default: every 5 minutes).
# This value is read by infrastructure tooling when deploying the Container Apps Job;
# the container itself performs one full reindex per invocation and then exits.
REINDEX_CRON_SCHEDULE=*/5 * * * *

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=
