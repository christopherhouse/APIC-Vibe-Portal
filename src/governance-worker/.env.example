# ============================================================================
# Governance Worker — local development environment variables
# ============================================================================
# Copy to .env and fill in values for local development/testing.
# NEVER commit actual secrets or credentials.

# Azure identity (leave blank to use full DefaultAzureCredential chain locally)
AZURE_CLIENT_ID=

# Azure API Center
API_CENTER_ENDPOINT=https://your-apic.data.eastus.azure-apicenter.ms
API_CENTER_WORKSPACE_NAME=default

# Azure Cosmos DB
COSMOS_DB_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DB_DATABASE_NAME=apic-vibe-portal
COSMOS_DB_GOVERNANCE_CONTAINER=governance-snapshots

# Observability (optional for local development)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Worker config
AGENT_ID=governance-worker
LOG_LEVEL=INFO
