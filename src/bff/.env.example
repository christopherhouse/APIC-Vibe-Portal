# ============================================================
# BFF Environment Variables
# Copy to .env and fill in values for local development
# ============================================================

# Server
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend origin (used by Azure Container Apps CORS config)
FRONTEND_URL=http://localhost:3000

# Entra ID (Azure AD) Authentication
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-bff-client-id
ENTRA_AUDIENCE=api://your-bff-client-id

# Azure API Center
API_CENTER_ENDPOINT=

# Azure AI Search
AI_SEARCH_ENDPOINT=

# Azure OpenAI
OPENAI_ENDPOINT=

# Azure Key Vault
KEY_VAULT_URL=

# Application Insights
APPINSIGHTS_CONNECTION_STRING=
