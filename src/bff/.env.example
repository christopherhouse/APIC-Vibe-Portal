# ============================================================
# BFF Environment Variables
# Copy to .env and fill in values for local development
# ============================================================

# Server
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend origin (used by Azure Container Apps CORS config)
FRONTEND_URL=http://localhost:3000

# Azure API Center
API_CENTER_ENDPOINT=
API_CENTER_SUBSCRIPTION_ID=
API_CENTER_RESOURCE_GROUP=
API_CENTER_SERVICE_NAME=
API_CENTER_WORKSPACE_NAME=default

# Azure AI Search
AI_SEARCH_ENDPOINT=
AI_SEARCH_INDEX_NAME=apic-apis

# Azure OpenAI
OPENAI_ENDPOINT=

# Azure Key Vault
KEY_VAULT_URL=

# Application Insights
APPINSIGHTS_CONNECTION_STRING=

# Entra ID (Authentication)
BFF_ENTRA_TENANT_ID=
BFF_ENTRA_CLIENT_ID=
BFF_ENTRA_AUDIENCE=
