# ============================================================
# BFF Environment Variables
# Copy to .env and fill in values for local development
# ============================================================

# Server
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend origin (used by Azure Container Apps CORS config)
FRONTEND_URL=http://localhost:3000

# Azure API Center
API_CENTER_ENDPOINT=

# Azure AI Search
AI_SEARCH_ENDPOINT=

# Azure OpenAI
OPENAI_ENDPOINT=

# Azure Key Vault
KEY_VAULT_URL=

# Application Insights
APPINSIGHTS_CONNECTION_STRING=

# Entra ID (Authentication)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUDIENCE=
